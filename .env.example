# Billit non-commercial authentication (preferred if you only automate your own administration)
BILLIT_API_KEY=your_billit_api_key

# Billit OAuth client credentials (optional; only needed when integrating via OAuth user consent flows)
BILLIT_CLIENT_ID=your_sandbox_client_id
BILLIT_CLIENT_SECRET=your_sandbox_client_secret
BILLIT_REDIRECT_URI=https://localhost:8787/oauth/billit/callback

# Billit API base URL
BILLIT_API_BASE_URL=https://api.sandbox.billit.be

# Default PartyID context for calls that require company context
BILLIT_PARTY_ID=123456

# Webhook signature secret
BILLIT_WEBHOOK_SECRET=replace_me
